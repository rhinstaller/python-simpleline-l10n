#. String to use in a prompt when we want users to press the key ENTER.
#: ../simpleline/render/prompt.py:35
msgid "ENTER"
msgstr "ĮVESTI"

#: ../simpleline/render/adv_widgets.py:72
msgid "Enter your passphrase"
msgstr "Įveskite slaptafrazę"

#: ../simpleline/render/adv_widgets.py:43
msgid "Error"
msgstr "Klaida"

#: ../simpleline/render/adv_widgets.py:167
msgid "Help"
msgstr "Pagalba"

#: ../simpleline/render/adv_widgets.py:85
msgid "Passphrase: "
msgstr "Slaptafrazė: "

#: ../simpleline/render/adv_widgets.py:71
msgid "Password"
msgstr "Slaptažodis"

#. Default message of the prompt
#: ../simpleline/render/prompt.py:32
msgid "Please make a selection from the above"
msgstr "Atrinkite iš aukščiau pateiktų"

#: ../simpleline/render/adv_widgets.py:132
#, python-format
msgid "Please respond '%(yes)s' or '%(no)s'"
msgstr "Atsakykite „%(yes)s“ arba „%(no)s“"

#: ../simpleline/render/adv_widgets.py:52
#, python-format
msgid "Press %s to exit"
msgstr "Spauskite %s, kad išeitumėte"

#: ../simpleline/render/adv_widgets.py:186
#, python-format
msgid "Press %s to return"
msgstr "Spauskite %s, kad grįžtumėte"

#: ../simpleline/render/adv_widgets.py:122
msgid "Question"
msgstr "Klausimas"

#: ../simpleline/render/adv_widgets.py:173
msgid "The help is not available."
msgstr "Pagalba nėra pasiekiama."

#. TRANSLATORS:'c' to continue
#: ../simpleline/render/prompt.py:42
msgid "to continue"
msgstr "tęsti"

#. TRANSLATORS:'h' to help
#: ../simpleline/render/prompt.py:50
msgid "to help"
msgstr "pagalba"

#. TRANSLATORS: 'q' to quit
#: ../simpleline/render/prompt.py:38
msgid "to quit"
msgstr "išeiti"

#. TRANSLATORS:'r' to refresh
#: ../simpleline/render/prompt.py:46
msgid "to refresh"
msgstr "įkelti iš naujo"
