#: ../simpleline/render/adv_widgets.py:41
msgid "Error"
msgstr "Klaida"

#: ../simpleline/render/adv_widgets.py:50
#, python-format
msgid "Press %s to exit"
msgstr "Spauskite %s, kad išeitumėte"

#: ../simpleline/render/adv_widgets.py:69
msgid "Password"
msgstr "Slaptažodis"

#: ../simpleline/render/adv_widgets.py:70
msgid "Enter your passphrase"
msgstr "Įveskite slaptafrazę"

#: ../simpleline/render/adv_widgets.py:83
msgid "Passphrase: "
msgstr "Slaptafrazė: "

#: ../simpleline/render/adv_widgets.py:120
msgid "Question"
msgstr "Klausimas"

#: ../simpleline/render/adv_widgets.py:130
#, python-format
msgid "Please respond '%(yes)s' or '%(no)s'"
msgstr "Atsakykite „%(yes)s“ arba „%(no)s“"

#: ../simpleline/render/adv_widgets.py:166
msgid "Help"
msgstr "Pagalba"

#: ../simpleline/render/adv_widgets.py:172
msgid "The help is not available."
msgstr "Pagalba nėra pasiekiama."

#: ../simpleline/render/adv_widgets.py:185
#, python-format
msgid "Press %s to return"
msgstr "Spauskite %s, kad grįžtumėte"

#. Default message of the prompt
#: ../simpleline/render/prompt.py:31
msgid "Please make a selection from the above"
msgstr "Atrinkite iš aukščiau pateiktų"

#. String to use in a prompt when we want users to press the key ENTER.
#: ../simpleline/render/prompt.py:34
msgid "ENTER"
msgstr "ĮVESTI"

#: ../simpleline/render/prompt.py:38
msgid "to quit"
msgstr "išeiti"

#: ../simpleline/render/prompt.py:42
msgid "to continue"
msgstr "tęsti"

#: ../simpleline/render/prompt.py:46
msgid "to refresh"
msgstr "įkelti iš naujo"

#: ../simpleline/render/prompt.py:50
msgid "to help"
msgstr "pagalba"
